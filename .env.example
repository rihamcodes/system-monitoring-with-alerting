# ==============================================================
# System Monitoring & Alerting — Environment Variables Template
# ==============================================================
# Copy this file to .env and fill in your real values.
# ✅  This file IS safe to commit — it contains no real secrets.
# ==============================================================

# --- Email (Gmail SMTP) ---
SMTP_FROM=your-email@gmail.com
SMTP_AUTH_USERNAME=your-email@gmail.com
SMTP_AUTH_PASSWORD=your-app-password-here

# --- Alert Recipients ---
ALERT_EMAIL_TO=your-email@gmail.com

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#monitoring-alerts

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-in-production
GF_USERS_ALLOW_SIGN_UP=false
